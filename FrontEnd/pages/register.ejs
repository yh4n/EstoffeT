<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="image/Icons/favicon-96x96(1).png" sizes="96x96" />
  <title>Registrar - Estoffe</title>

  <link rel="icon" type="image/png" href="/FrontEnd/image/Icons/favicon-96x96.png" sizes="96x96" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="css/style.css">
</head>

<body>

  <header id="main-header"
    class="flex items-center justify-between p-4 bg-green-950 shadow-md fixed top-0 left-0 w-full z-50 transition-all duration-500">

    <a id="header-logo" href="/" class="flex items-center">
      <img id="logo-img" src="../image/LogoNavBar.png" alt="Logo Estoffe"
        class="h-16 md:h-19 w-auto transition-all duration-500">
    </a>

    <button id="menu-btn" class="block md:hidden text-white focus:outline-none z-50">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16">
        </path>
      </svg>
    </button>


    <nav id="menu"
      class="fixed left-0 -top-full w-full h-screen bg-green-900/90 flex flex-col items-center justify-center transition-all duration-300 md:static md:h-auto md:w-auto md:flex-row md:bg-transparent">
      <ul
        class="flex flex-col items-center gap-8 text-sm font-medium uppercase tracking-widest md:flex-row md:space-x-8 md:gap-0">
        <li>
          <a href="/" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
            <i class="bi bi-house-door mr-1"></i>Início
          </a>
        </li>
        <li>
          <a href="/produtos" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
            <i class="bi bi-bag mr-1"></i>Produtos
          </a>
        </li>
        <li>
          <a href="/sobre" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
            <i class="bi bi-info-circle mr-1"></i>Sobre
          </a>
        </li>
        <li>
          <a href="/contato" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
            <i class="bi bi-envelope mr-1"></i>Contato
          </a>
        </li>

        <li>
          <a href="/login" class="nav-link-item text-white font-bold transition-colors duration-300" data-active="true">
            <i class="bi bi-person mr-1"></i>Login
          </a>
        </li>

      </ul>
    </nav>
  </header>

  <section class="relative bg-green-950 text-white pt-50 pb-30 px-6 md:px-25 lg:px-33 overflow-hidden">
  </section>

  <main class="py-20 px-6 md:px-16 lg:px-24 flex-grow">
    <% if (typeof error !=='undefined' && error) { %>
      <div class="mb-6 p-3 bg-red-500/20 border border-red-500 text-red-200 rounded text-sm text-center font-medium">
        <%= error %>
      </div>
    <% } %>

    <form action="/register" method="POST" class="space-y-6 max-w-4xl mx-auto bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700">Nome</label>
          <input type="text" id="name" name="nome" required
            class="mt-1 block w-full px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-900 focus:ring-green-500 focus:border-green-500">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">E-mail</label>
          <input type="email" name="email" required
            class="mt-1 block w-full px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-900 focus:ring-green-500 focus:border-green-500">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="telefone" class="block text-sm font-medium text-gray-700">Telefone / WhatsApp</label>
          <input type="text" id="telefone" name="telefone" placeholder="(48) 99999-9999" required
            class="mt-1 block w-full px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-900 focus:ring-green-500 focus:border-green-500">
        </div>

        <div>
          <label for="novaSenha" class="block text-sm font-medium text-gray-700">Sua Senha</label>
          <input type="password" id="novaSenha" name="novaSenha" placeholder="No mínimo 8 caracteres" required
            class="mt-1 block w-full px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-900 focus:ring-green-500 focus:border-green-500">
        </div>
      </div>

      <div>
        <label for="endereco" class="block text-sm font-medium text-gray-700">Endereço Completo de Entrega</label>
        <input type="text" id="endereco" name="endereco" placeholder="Rua, Número, Bairro, Cidade/UF" required
          class="mt-1 block w-full px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-900 focus:ring-green-500 focus:border-green-500">
      </div>

      <hr class="border-gray-200 my-6" />

      <div class="flex justify-end pt-4">
        <button type="submit"
          class="px-6 py-2.5 bg-green-900 hover:bg-green-800 text-white font-semibold rounded-md transition-colors duration-300 flex items-center gap-2 shadow-md">
          <i class="bi bi-check-circle"></i> Cadastrar
        </button>
      </div>
    </form>
  </main>

  <footer class="bg-green-950 text-gray-400 text-sm py-12 px-6 md:px-16 lg:px-24 border-t border-green-900">
    <div
      class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
      <div>
        <p class="text-white font-bold text-lg tracking-wider uppercase">Estoffe</p>
        <p class="text-xs text-gray-400 mt-1">&copy; 2026 Estoffe Estofaria Premium. Todos os direitos reservados.</p>
      </div>

      <div class="flex space-x-6 text-xl">
        <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-instagram"></i></a>
        <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-facebook"></i></a>
        <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-whatsapp"></i></a>
      </div>
    </div>
  </footer>

  <script>
  const inputTelefone = document.getElementById('telefone');

  inputTelefone.addEventListener('input', (e) => {
    let valor = e.target.value;
    
    // Remove qualquer caractere que não seja número
    valor = valor.replace(/\D/g, '');
    
    // Aplica a formatação dinamicamente conforme o tamanho do texto
    if (valor.length > 0) {
      valor = '(' + valor;
    }
    if (valor.length > 3) {
      valor = valor.slice(0, 3) + ') ' + valor.slice(3);
    }
    if (valor.length > 10) {
      // Formato para celular: (XX) XXXXX-XXXX
      valor = valor.slice(0, 10) + '-' + valor.slice(10, 14);
    } else if (valor.length > 7) {
      // Formato temporário enquanto digita ou para telefone fixo: (XX) XXXX-XXXX
      valor = valor.slice(0, 9) + '-' + valor.slice(9);
    }
    
    // Atualiza o valor do input na tela
    e.target.value = valor;
  });
</script>
  <script src="pages/animacoes/anima.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
    integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
    crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"
    integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y"
    crossorigin="anonymous"></script>
</body>

</html>