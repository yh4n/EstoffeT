<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estoffe</title>

    <link rel="icon" type="image/png" href="../image/Icons/favicon-96x96.png" sizes="96x96" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="../css/style.css">
</head>

<body class="bg-gray-100 font-sans">

    <header id="main-header" class="flex items-center justify-between p-4 bg-green-950 shadow-md fixed top-0 left-0 w-full z-50 transition-all duration-500">

    <a id="header-logo" href="/" class="flex items-center">
        <img id="logo-img" src="../image/LogoNavBar.png" alt="Logo Estoffe" class="h-16 md:h-19 w-auto transition-all duration-500">
    </a>

    <nav id="menu" class="fixed left-0 -top-full w-full h-screen bg-green-900/90 shadow-lg shadow-green-950/50 flex flex-col items-center justify-center transition-all duration-300 md:static md:h-auto md:w-auto md:flex-row md:bg-transparent backdrop-blur-3xl md:backdrop-blur-none md:shadow-none">
        <ul class="flex flex-col items-center gap-8 text-sm font-medium uppercase tracking-widest md:flex-row md:space-x-8 md:gap-0">
            <li>
                <% if (typeof usuario !=='undefined' && usuario) { %>
                    <a href="/" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                        <i class="bi bi-house-door mr-1"></i>Início
                    </a>
                <% } else { %>
                    <a href="/" class="nav-link-item text-white font-bold transition-colors duration-300" data-active="true">
                        <i class="bi bi-house-door mr-1"></i>Início
                    </a>
                <% } %>
            </li>
            <li>
                <a href="/produtos" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                    <i class="bi bi-bag mr-1"></i>Produtos
                </a>
            </li>
            <li>
                <a href="/sobre" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                    <i class="bi bi-info-circle mr-1"></i>Sobre
                </a>
            </li>
            <li>
                <a href="/contato" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                    <i class="bi bi-envelope mr-1"></i>Contato
                </a>
            </li>

            <% if (typeof usuario !=='undefined' && usuario) { %>
                <% if (usuario.tipo==='admin' ) { %>
                    <li>
                        <a href="/admin-dashboard" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                            <i class="bi bi-shield-lock mr-1"></i> Painel Administrativo
                        </a>
                    </li>
                <% } else if (usuario.tipo==='estofador' ) { %>
                    <li>
                        <a href="/estofador-dashboard" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                            <i class="bi bi-tools mr-1"></i> Painel do Estofador
                        </a>
                    </li>
                <% } else { %>
                    <li>
                        <a href="<%= usuario.tipo === 'client' ? '/client-dashboard' : '/perfil' %>" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                            <i class="bi bi-person-circle mr-1"></i> Meu Perfil
                        </a>
                    </li>
                <% } %>
                <li>
                    <a href="/logout" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                        <i class="bi bi-box-arrow-right mr-1"></i> Sair
                    </a>
                </li>
            <% } else { %>
                <li>
                    <a href="/login" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                        <i class="bi bi-person mr-1"></i> Login
                    </a>
                </li>
            <% } %>
        </ul>
    </nav>

    <div class="flex items-center gap-4 z-50">
        
        <a href="/carrinho" class="relative nav-link-item text-gray-300 hover:text-white transition-colors duration-300 p-2" aria-label="Carrinho de compras">
            <i class="bi bi-cart3 text-xl md:text-2xl"></i>
            <span id="cart-count" class="absolute top-0 right-0 bg-red-600 text-white font-bold text-[10px] w-4 h-4 rounded-full flex items-center justify-center shadow-sm">
                0
            </span>
        </a>

        <button id="menu-btn" class="block md:hidden text-white focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>

    </div>

</header>

    <section class="hero text-white relative overflow-hidden">
        <div class="hero-content flex flex-col lg:flex-row items-center justify-between min-h-screen bg-gray-100 px-6 md:px-16 lg:px-24 pt-24 gap-12" id="inicio">

            <div class="flex flex-col items-start text-left max-w-2xl lg:w-7/12">
                <span class="text-xs font-bold uppercase tracking-[0.3em] text-green-700 mb-4 block">
                    Design & Conforto Premium
                </span>

                <section class="prose">
                    <% if (typeof usuario !=='undefined' && usuario) { %>
                        <h1 class="text-4xl sm:text-5xl md:text-6xl font-light text-gray-900 tracking-tight leading-none mb-6">
                            Olá, <%= usuario.nome.toUpperCase() %>!</h1>
                        <% } else { %>
                            <h1 class="text-4xl sm:text-5xl md:text-6xl font-light text-gray-900 tracking-tight leading-none mb-6">
                                Bem-vindo à <span class="font-extrabold text-green-950 block mt-2">ESTOFFE!</span></h1>
                            <% } %>
                </section>

                <div class="w-16 h-[2px] bg-green-700 mb-6"></div>

                <p class="text-base md:text-lg text-gray-600 font-normal mb-8 max-w-xl leading-relaxed">
                    Explore nossa coleção exclusiva de estofados de alto padrão. Unimos sofisticação, ergonomia e o
                    aconchego que o seu ambiente merece.
                </p>

                <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
                    <a href="produtos.html" class="w-full sm:w-auto text-center inline-block bg-green-950 hover:bg-green-800 text-white font-semibold px-8 py-4 rounded-sm shadow-md transition-all duration-300 uppercase tracking-widest text-xs">
                        Ver Produtos
                    </a>
                    <a href="contato.html" class="w-full sm:w-auto text-center inline-block bg-transparent hover:bg-gray-200 text-green-950 font-semibold px-8 py-4 rounded-sm transition-all duration-300 uppercase tracking-widest text-xs border border-green-950/30 hover:border-green-950">
                        Faça um Orçamento
                    </a>
                </div>
            </div>

            <div class="lg:w-5/12 w-full flex items-center justify-center lg:justify-end animate-fade-in">
                <div class="relative w-full max-w-sm aspect-square bg-green-900/10 rounded-sm flex items-center justify-center p-8 border border-green-900/20">
                    <div class="absolute -top-4 -left-4 w-12 h-12 border-t-2 border-l-2 border-green-900/40"></div>
                    <div class="absolute -bottom-4 -right-4 w-12 h-12 border-b-2 border-r-2 border-green-900/40"></div>

                    <div class="text-center">
                        <p class="text-3xl font-serif italic text-green-950">Estoffe</p>
                        <p class="text-xs uppercase tracking-widest text-gray-500 mt-2">Conceito & Loft</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-gray-100 px-6 md:px-16 lg:px-24 border-t border-b border-gray-100">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <span class="text-xs font-bold uppercase tracking-[0.4em] text-green-700 mb-3 block">Nossos
                    Pilares</span>
                <h2 class="text-3xl md:text-4xl font-light text-gray-900 tracking-tight">O Padrão <span class="font-extrabold text-green-950">Estoffe</span></h2>
                <div class="w-12 h-[2px] bg-green-700 mx-auto mt-4"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                <div class="flex flex-col items-center text-center p-4">
                    <div class="w-14 h-14 bg-green-950/5 rounded-sm flex items-center justify-center mb-6 text-green-950">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-3">Ergonomia Avançada</h3>
                    <p class="text-sm text-gray-600 font-light leading-relaxed max-w-xs">
                        Móveis projetados milimetricamente para respeitar a postura corporal, gerando bem-estar real no
                        seu dia a dia.
                    </p>
                </div>

                <div class="flex flex-col items-center text-center p-4">
                    <div class="w-14 h-14 bg-green-950/5 rounded-sm flex items-center justify-center mb-6 text-green-950">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-3">Produção Sustentável</h3>
                    <p class="text-sm text-gray-600 font-light leading-relaxed max-w-xs">
                        Madeiras certificadas com selo FSC e espumas livres de CFC. Produzimos pensando no futuro do
                        nosso planeta.
                    </p>
                </div>

                <div class="flex flex-col items-center text-center p-4">
                    <div class="w-14 h-14 bg-green-950/5 rounded-sm flex items-center justify-center mb-6 text-green-950">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-3">100% Personalizável</h3>
                    <p class="text-sm text-gray-600 font-light leading-relaxed max-w-xs">
                        Escolha as dimensões exatas, texturas e cores das centenas de tecidos nobres do nosso catálogo
                        exclusivo.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-white px-6 md:px-16 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <span class="text-xs font-bold uppercase tracking-[0.3em] text-green-700 mb-3 block">Coleção
                    Exclusiva</span>
                <h2 class="text-3xl md:text-4xl font-light text-gray-900 tracking-tight">
                    Nossos <span class="font-extrabold text-green-950">Produtos</span>
                </h2>
                <div class="w-12 h-[2px] bg-green-700 mx-auto mt-4"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

                <div class="group relative bg-gray-50 rounded-sm overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
                    <div>
                        <div class="aspect-square w-full overflow-hidden bg-gray-200 relative">
                            <span class="absolute top-4 left-4 z-10 bg-green-950 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-sm">Alta
                                Costura</span>
                            <img src="../image/cabeceiraTeste.jpg" alt="Cabeceira Premium Estoffe" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Cabeceira Atelier</h3>
                            <p class="text-sm text-gray-600 font-light leading-relaxed mb-4">
                                Acabamento artesanal em gomos lineares com espuma soft de alta resiliência. Desenhada
                                para emoldurar sua cama com imponência e suavidade visual.
                            </p>
                            <span class="text-xs uppercase font-semibold text-gray-400 tracking-wider block">Sob
                                Medida</span>
                        </div>
                    </div>
                    <div class="p-6 pt-0">
                        <a href="produtos.html" class="w-full text-center inline-block bg-green-950 hover:bg-green-800 text-white font-semibold px-4 py-3 rounded-sm transition-colors duration-300 uppercase tracking-wider text-xs">
                            Ver Detalhes
                        </a>
                    </div>
                </div>

                <div class="group relative bg-gray-50 rounded-sm overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
                    <div>
                        <div class="aspect-square w-full overflow-hidden bg-gray-200 relative">
                            <span class="absolute top-4 left-4 z-10 bg-green-700 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-sm">Mais
                                Vendido</span>
                            <img src="../image/sofaTeste.jpg" alt="Sofá Minimalista Estoffe" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Sofá Minimalist Linho</h3>
                            <p class="text-sm text-gray-600 font-light leading-relaxed mb-4">
                                Modulado versátil estruturado em madeira de reflorestamento imunizada. Revestimento em
                                linho rústico importado com toque extremamente macio.
                            </p>
                            <span class="text-xs uppercase font-semibold text-gray-400 tracking-wider block">Disponível
                                em 4 cores</span>
                        </div>
                    </div>
                    <div class="p-6 pt-0">
                        <a href="produtos.html" class="w-full text-center inline-block bg-green-950 hover:bg-green-800 text-white font-semibold px-4 py-3 rounded-sm transition-colors duration-300 uppercase tracking-wider text-xs">
                            Ver Detalhes
                        </a>
                    </div>
                </div>

                <div class="group relative bg-gray-50 rounded-sm overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
                    <div>
                        <div class="aspect-square w-full overflow-hidden bg-gray-200 relative">
                            <img src="../image/Puff.jpg" alt="Puff Orgânico Estoffe" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Puff Orgânico Drop</h3>
                            <p class="text-sm text-gray-600 font-light leading-relaxed mb-4">
                                A peça curinga para o seu living. Formas fluidas inspiradas no design escandinavo
                                contemporâneo, perfeito para assento extra ou apoio sofisticado.
                            </p>
                            <span class="text-xs uppercase font-semibold text-gray-400 tracking-wider block">Opção
                                Bouclé ou Couro</span>
                        </div>
                    </div>
                    <div class="p-6 pt-0">
                        <a href="produtos.html" class="w-full text-center inline-block bg-green-950 hover:bg-green-800 text-white font-semibold px-4 py-3 rounded-sm transition-colors duration-300 uppercase tracking-wider text-xs">
                            Ver Detalhes
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section class="py-20 bg-gray-50 px-6 md:px-16 lg:px-24">
        <div class="max-w-4xl mx-auto text-center">
            <span class="text-xs font-bold uppercase tracking-[0.3em] text-green-700 mb-4 block">Experiência do
                Cliente</span>
            <span class="text-6xl font-serif text-green-950/20 block leading-none mb-2">“</span>

            <p class="text-lg md:text-xl font-light text-gray-800 italic leading-relaxed mb-6">
                "A experiência de compra na Estoffe superou todas as expectativas. O sofá Minimalist em linho
                transformou completamente o ambiente da nossa sala. O conforto é absurdo e os detalhes de acabamento são
                impecáveis."
            </p>

            <div class="w-6 h-[1px] bg-green-700 mx-auto mb-4"></div>

            <h4 class="text-sm font-bold uppercase tracking-widest text-green-950">Mariana & Roberto Dias</h4>
            <p class="text-xs text-gray-400 mt-1">São Paulo - SP</p>
        </div>
    </section>

    <footer class="bg-green-950 text-gray-400 text-sm py-12 px-6 md:px-16 lg:px-24 mt-auto border-t border-green-900">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
            <div>
                <p class="text-white font-bold text-lg tracking-wider uppercase">Estoffe</p>
                <p class="text-xs text-gray-400 mt-1">&copy; 2026 Estoffe Estofaria Premium. Todos os direitos
                    reservados.</p>
            </div>

            <div class="flex space-x-6 text-xl">
                <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-instagram"></i></a>
                <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-facebook"></i></a>
                <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-whatsapp"></i></a>
            </div>
        </div>
    </footer>

    <script src="/../pages/animacoes/anima.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"></script>
</body>

</html>