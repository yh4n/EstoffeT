<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel do Estofador - Estoffe Oficina</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-gray-50 min-h-screen">

  <nav class="bg-zinc-800 text-white px-6 py-4 flex justify-between items-center shadow-md">
    <div class="flex items-center gap-3">
      <span class="text-xl font-bold tracking-wider uppercase">Estoffe Oficina</span>
      <span
        class="bg-amber-500 text-xs px-2.5 py-0.5 rounded-full font-semibold uppercase tracking-wide text-zinc-950">Oficina</span>
    </div>
    <a href="/login"
      class="text-gray-300 hover:text-white transition-colors flex items-center gap-1.5 text-sm font-medium">
      <i class="bi bi-box-arrow-right"></i> Sair do Sistema
    </a>
  </nav>

  <main class="p-6 md:p-12 max-w-7xl mx-auto">

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-800">Olá, <%= usuario.nome %>!</h1>
      <p class="text-gray-600 mt-1">Visão geral da sua área de trabalho, controle de produção e serviços atribuídos.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">

      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Em Execução</p>
          <h3 class="text-3xl font-bold text-gray-800 mt-1">
            <%= indicadores.iniciados %>
          </h3>
        </div>
        <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center text-amber-600 text-xl">
          <i class="bi bi-tools"></i>
        </div>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Concluídos</p>
          <h3 class="text-3xl font-bold text-gray-800 mt-1">
            <%= indicadores.concluidos %>
          </h3>
        </div>
        <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600 text-xl">
          <i class="bi bi-check2-all"></i>
        </div>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Cancelados</p>
          <h3 class="text-3xl font-bold text-gray-800 mt-1">
            <%= indicadores.cancelados %>
          </h3>
        </div>
        <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-600 text-xl">
          <i class="bi bi-x-circle"></i>
        </div>
      </div>

    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/70">
        <h3 class="font-bold text-gray-700 flex items-center gap-2"><i class="bi bi-list-task text-zinc-700"></i>
          Histórico da sua Área</h3>
      </div>

      <div class="p-6 overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="text-xs font-semibold text-gray-500 uppercase border-b border-gray-200">
              <th class="pb-3">Nº Pedido (OS)</th>
              <th class="pb-3">Cliente</th>
              <th class="pb-3">Data de Atribuição</th>
              <th class="pb-3">Status Atual</th>
              <th class="pb-3 text-right">Ação</th>
            </tr>
          </thead>
          <tbody class="text-sm divide-y divide-gray-100 text-gray-600">
            <% if (ordens && ordens.length> 0) { %>
              <% ordens.forEach(function(ordem) { %>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="py-4 font-bold text-zinc-800">#<%= ordem.codPedido %>
                  </td>

                  <td class="py-4 font-medium text-gray-800">
                    <%= ordem.nomeCliente %>
                  </td>

                  <td class="py-4">
                    <%= ordem.dataPedido ? new Date(ordem.dataPedido).toLocaleDateString('pt-BR') : '---' %>
                  </td>

                  <td class="py-4">
                    <% if (ordem.status==='Em Produção' ) { %>
                      <span class="bg-amber-100 text-amber-800 text-xs px-2.5 py-1 rounded-full font-medium">Iniciado /
                        Oficina</span>
                      <% } else if (ordem.status==='Pronto' || ordem.status==='Entregue' ) { %>
                        <span
                          class="bg-green-100 text-green-800 text-xs px-2.5 py-1 rounded-full font-medium">Concluído</span>
                        <% } else { %>
                          <span class="bg-red-100 text-red-800 text-xs px-2.5 py-1 rounded-full font-medium">
                            <%= ordem.status %>
                          </span>
                          <% } %>
                  </td>

                  <td class="py-4 text-right">
                    <div class="inline-flex items-center gap-2">

                      <% if (ordem.status==='Em Produção' ) { %>
                        <form action="/admin/pedido/<%= ordem.codPedido %>/status" method="POST" class="inline-block">
                          <input type="hidden" name="novoStatus" value="Pronto">
                          <button type="submit"
                            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-zinc-800 hover:bg-zinc-700 text-white rounded-lg text-xs font-semibold transition-colors shadow-sm">
                            <i class="bi bi-check2-circle"></i> Finalizar Serviço
                          </button>
                        </form>
                        <% } else { %>
                          <span class="text-xs text-gray-400 italic mr-2">Concluído</span>
                          <% } %>

                            <a href="/estofador/pedido/<%= ordem.codPedido %>/detalhes"
                              class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 hover:bg-blue-100 text-blue-700 rounded-lg text-xs font-semibold transition-colors shadow-sm border border-blue-100">
                              <i class="bi bi-search text-xs"></i> Detalhes
                            </a>

                    </div>
                  </td>
                </tr>
                <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="5" class="py-8 text-center text-gray-400">Nenhum serviço registrado para você até o
                        momento.</td>
                    </tr>
                    <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

</body>

</html>