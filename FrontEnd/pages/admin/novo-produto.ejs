<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estoffe Admin - Novo Produto</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-gray-50 font-sans min-h-screen flex flex-col">

    <header class="bg-green-950 text-white px-6 py-4 flex justify-between items-center shadow-md">
        <div class="flex items-center gap-3">
            <span class="font-bold tracking-wider text-lg">ESTOFFE ADMIN</span>
            <span class="bg-red-500 text-white text-[10px] font-bold uppercase px-2 py-0.5 rounded-sm">Gerente</span>
        </div>
        <a href="/produtos" class="text-sm text-gray-300 hover:text-white transition flex items-center gap-1">
            <i class="bi bi-speedometer2"></i> Voltar ao Painel
        </a>
    </header>

    <main class="flex-grow flex items-center justify-center py-12 px-4">
        <div class="bg-white rounded-sm border border-gray-100 shadow-xl max-w-lg w-full p-8">

            <div class="mb-6">
                <h2 class="text-2xl font-bold text-gray-900">Cadastrar Novo Produto</h2>
                <p class="text-sm text-gray-500 mt-1">Insira os detalhes da nova peça de alto padrão para o catálogo.
                </p>
            </div>

            <form action="/admin/produtos/salvar" method="POST" class="space-y-5">

                <div>
                    <label for="nome" class="block text-xs font-bold uppercase tracking-wider text-gray-700 mb-1">Nome
                        do Produto</label>
                    <input type="text" id="nome" name="nome" required placeholder="Ex: Sofá Chesterfield Linho"
                        class="w-full border border-gray-200 px-4 py-3 rounded-sm text-sm focus:outline-none focus:border-green-800 transition">
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label for="preco"
                            class="block text-xs font-bold uppercase tracking-wider text-gray-700 mb-1">Preço
                            (R$)</label>
                        <input type="number" id="preco" name="preco" step="0.01" required placeholder="0.00"
                            class="w-full border border-gray-200 px-4 py-3 rounded-sm text-sm focus:outline-none focus:border-green-800 transition">
                    </div>

                    <div>
                        <label for="codCategoria"
                            class="block text-xs font-bold uppercase tracking-wider text-gray-700 mb-1">Categoria</label>
                        <select id="codCategoria" name="codCategoria" required
                            class="w-full bg-white border border-gray-200 px-4 py-3 rounded-sm text-sm focus:outline-none focus:border-green-800 transition">
                            <option value="" disabled selected>Selecione...</option>

                            <% categorias.forEach(categoria=> { %>
                                <option value="<%= categoria.codCategoria %>">
                                    <%= categoria.nome %>
                                </option>
                                <% }) %>

                        </select>
                    </div>
                </div>

                <div>
                    <label for="imagem"
                        class="block text-xs font-bold uppercase tracking-wider text-gray-700 mb-1">Caminho da
                        Imagem</label>
                    <input type="text" id="imagem" name="imagem" placeholder="Ex: image/sofa-novo.jpg"
                        class="w-full border border-gray-200 px-4 py-3 rounded-sm text-sm focus:outline-none focus:border-green-800 transition">
                    <p class="text-[11px] text-gray-400 mt-1">Insira a pasta e o nome do arquivo salvo no seu projeto.
                    </p>
                </div>

                <div class="pt-2">
                    <button type="submit"
                        class="w-full bg-green-950 hover:bg-green-800 text-white font-semibold py-3 px-4 rounded-sm transition duration-300 uppercase tracking-wider text-xs flex items-center justify-center gap-2 cursor-pointer">
                        <i class="bi bi-plus-circle"></i> Salvar Produto
                    </button>
                </div>
            </form>

        </div>
    </main>

</body>

</html>