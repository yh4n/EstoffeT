<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trabalhos de <%= estofador.nome %> - Estoffe Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-gray-50 min-h-screen">

    <nav class="bg-green-950 text-white px-6 py-4 flex justify-between items-center shadow-md">
        <span class="text-xl font-bold tracking-wider">ESTOFFE ADMIN</span>
        <a href="/admin/estofadores"
            class="text-gray-300 hover:text-white transition-colors text-sm flex items-center gap-1">
            <i class="bi bi-arrow-left"></i> Voltar para Estofadores
        </a>
    </nav>

    <main class="p-6 md:p-12 max-w-5xl mx-auto">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Histórico de Produção</h1>
            <p class="text-gray-600 mt-1">Listagem de ordens de serviço atribuídas ao profissional <strong>
                    <%= estofador.nome %>
                </strong>.</p>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="p-6 overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-xs font-semibold text-gray-500 uppercase border-b border-gray-200">
                            <th class="pb-3">Nº OS / Pedido</th>
                            <th class="pb-3">Cliente</th>
                            <th class="pb-3">Data de Atribuição</th>
                            <th class="pb-3">Status</th>
                            <th class="pb-3 text-right">Ação</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-100 text-gray-600">
                        <% if (trabalhos && trabalhos.length> 0) { %>
                            <% trabalhos.forEach(function(servico) { %>
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="py-4 font-bold text-zinc-800">#<%= servico.codPedido %>
                                    </td>
                                    <td class="py-4 font-medium text-gray-800">
                                        <%= servico.nomeCliente %>
                                    </td>
                                    <td class="py-4">
                                        <%= servico.dataPedido ? new
                                            Date(servico.dataPedido).toLocaleDateString('pt-BR') : '---' %>
                                    </td>
                                    <td class="py-4">
                                        <% if (servico.status==='Em Produção' ) { %>
                                            <span
                                                class="bg-amber-100 text-amber-800 text-xs px-2.5 py-1 rounded-full font-medium">Na
                                                Oficina</span>
                                            <% } else if (servico.status==='Pronto' || servico.status==='Entregue' ) {
                                                %>
                                                <span
                                                    class="bg-green-100 text-green-800 text-xs px-2.5 py-1 rounded-full font-medium">Concluído</span>
                                                <% } else { %>
                                                    <span
                                                        class="bg-gray-100 text-gray-800 text-xs px-2.5 py-1 rounded-full font-medium">
                                                        <%= servico.status %>
                                                    </span>
                                                    <% } %>
                                    </td>
                                    <td class="py-4 text-right">
                                        <a href="/admin/estofador-analisa/<%= servico.codPedido %>"
                                            class="text-blue-600 hover:underline font-semibold text-xs">
                                            Ver Detalhes
                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5" class="py-8 text-center text-gray-400">Este profissional
                                                ainda não possui trabalhos registrados.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>

</html>