<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analisar Pedido #<%= pedido.codPedido %> - Estoffe Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="icon" type="image/png" href="../../image/Icons/favicon-96x96.png" sizes="96x96" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-gray-50 min-h-screen">

  <nav class="bg-green-950 text-white px-6 py-4 flex justify-between items-center shadow-md">
    <div class="flex items-center gap-3">
      <span class="text-xl font-bold tracking-wider">ESTOFFE ADMIN</span>
      <span class="bg-red-500 text-xs px-2.5 py-0.5 rounded-full font-semibold uppercase tracking-wide">Gerente</span>
    </div>
    <a href="/admin/orcamentos"
      class="text-gray-300 hover:text-white transition-colors flex items-center gap-1.5 text-sm font-medium">
      <i class="bi bi-arrow-left"></i> Voltar para Orçamentos
    </a>
  </nav>

  <main class="p-6 md:p-12 max-w-4xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-6 md:p-8">

      <div
        class="border-b border-gray-100 pb-6 mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <span
            class="text-xs font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2.5 py-1 rounded-md">Orçamento
            em Triagem</span>
          <h1 class="text-2xl font-bold text-gray-800 mt-2">Pedido #<%= pedido.codPedido %>
          </h1>
          <p class="text-sm text-gray-500 mt-1">Recebido em: <%= pedido.dataPedido ? new
              Date(pedido.dataPedido).toLocaleDateString('pt-BR') : '---' %>
          </p>
        </div>
        <div>
          <span class="bg-amber-100 text-amber-800 text-xs px-3 py-1.5 rounded-full font-semibold">
            <%= pedido.status %>
          </span>
        </div>
      </div>

      <!-- Dados do Cliente -->
      <div class="mb-8">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Dados do Cliente</h3>
        <div class="bg-gray-50 p-4 rounded-xl border border-gray-100 grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-gray-500">Nome Completo</p>
            <p class="font-medium text-gray-800">
              <%= pedido.nomeCliente %>
            </p>
          </div>
          <div>
            <p class="text-xs text-gray-500">E-mail de Contato</p>
            <p class="font-medium text-gray-800">
              <%= pedido.emailCliente %>
            </p>
          </div>
        </div>
      </div>

      <!-- Itens Solicitados -->
      <div class="mt-6 border-t border-gray-100 pt-6">
        <h3 class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-4">Itens Solicitados</h3>
        <div class="bg-gray-50 rounded-sm p-4 border border-gray-100">
          <% if (pedido.itens && pedido.itens.length> 0) { %>
            <div class="divide-y divide-gray-200">
              <% pedido.itens.forEach(function(item) { %>
                <div class="py-3 flex justify-between items-center first:pt-0 last:pb-0">
                  <div>
                    <p class="font-semibold text-gray-800 text-sm">
                      <%= item.nomeProduto %>
                    </p>
                    <p class="text-xs text-gray-500 italic mt-1">
                      <strong>Obs:</strong>
                      <%= item.observacaoProduto || 'Nenhuma observação informada.' %>
                    </p>
                    <p class="text-xs text-gray-400 mt-0.5">
                      Preço Unitário: R$ <%= Number(item.precoUnitario).toFixed(2).replace('.', ',' ) %>
                    </p>
                  </div>
                  <div class="text-right">
                    <span class="text-xs font-bold bg-green-100 text-green-800 px-2.5 py-0.5 rounded-sm">
                      Qtd: <%= item.quantidade %>
                    </span>
                    <p class="text-xs font-bold text-gray-700 mt-1">
                      Total: R$ <%= (Number(item.quantidade) * Number(item.precoUnitario)).toFixed(2).replace('.', ',' )
                        %>
                    </p>
                  </div>
                </div>
                <% }); %>
            </div>
            <% } else { %>
              <p class="text-sm text-gray-500 italic">Nenhum item vinculado a este orçamento no banco de dados.</p>
              <% } %>
        </div>
      </div>

      <!-- Ações do Gerente -->
      <div class="border-t border-gray-100 pt-6 flex flex-col md:flex-row justify-between items-end gap-6">
        <form action="/admin/pedido/<%= pedido.codPedido %>/status" method="POST">
          <input type="hidden" name="novoStatus" value="Cancelado">
          <button type="submit"
            class="w-full sm:w-auto px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg transition-colors text-sm">
            Recusar Orçamento
          </button>
        </form>

        <form action="/admin/pedido/<%= pedido.codPedido %>/status" method="POST"
          class="w-full md:max-w-md flex flex-col sm:flex-row items-end gap-3">
          <input type="hidden" name="novoStatus" value="Em Produção">

          <div class="w-full">
            <label for="codEstofador"
              class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Selecione o Estofador
              Responsável *</label>
            <select name="codEstofador" id="codEstofador" required
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-green-950">
              <option value="" disabled selected>Escolha um profissional...</option>
              <% estofadores.forEach(function(estofador) { %>
                <option value="<%= estofador.codUsuario %>">
                  <%= estofador.nome %>
                </option>
                <% }); %>
            </select>
          </div>

          <button type="submit"
            class="w-full sm:w-auto px-5 py-2.5 bg-green-950 hover:bg-green-900 text-white font-medium rounded-lg transition-colors shadow-sm text-sm whitespace-nowrap h-[40px]">
            Aprovar e Iniciar
          </button>
        </form>

      </div>

    </div>

    </div>
  </main>

</body>

</html>