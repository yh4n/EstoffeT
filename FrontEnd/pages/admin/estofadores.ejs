<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Estofadores Ativos - Estoffe Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-gray-50 min-h-screen">

  <nav class="bg-green-950 text-white px-6 py-4 flex justify-between items-center shadow-md">
    <div class="flex items-center gap-3">
      <span class="text-xl font-bold tracking-wider">ESTOFFE ADMIN</span>
      <span class="bg-red-500 text-xs px-2.5 py-0.5 rounded-full font-semibold uppercase tracking-wide">Gerente</span>
    </div>
    <a href="/admin-dashboard"
      class="text-gray-300 hover:text-white transition-colors flex items-center gap-1.5 text-sm font-medium">
      <i class="bi bi-speedometer2"></i> Voltar ao Painel
    </a>
  </nav>

  <main class="p-6 md:p-12 max-w-7xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-800">Estofadores Ativos</h1>
        <p class="text-gray-600 mt-1">Lista completa de profissionais cadastrados na oficina de produção.</p>
      </div>

      <button onclick="abrirModalNovo()"
        class="px-4 py-2.5 bg-green-900 hover:bg-green-800 text-white font-semibold rounded-md transition-colors shadow-sm flex items-center gap-2 text-sm">
        <i class="bi bi-person-plus"></i> Novo Estofador
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if (estofadores && estofadores.length> 0) { %>
        <% estofadores.forEach(function(estofador) { %>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-700 text-xl font-bold shrink-0">
                <%= estofador.nome.charAt(0).toUpperCase() %>
              </div>
              <div class="overflow-hidden">
                <h3 class="font-bold text-gray-800 text-lg truncate">
                  <%= estofador.nome %>
                </h3>
                <p class="text-sm text-gray-500 flex items-center gap-1.5 mt-0.5 truncate">
                  <i class="bi bi-envelope text-gray-400"></i>
                  <%= estofador.email %>
                </p>
                <p class="text-xs text-gray-400 mt-1 flex items-center gap-1">
                  <span class="w-2 h-2 rounded-full bg-green-500 inline-block"></span> ID do Usuário: #<%=
                    estofador.codUsuario %>
                </p>
              </div>
            </div>

            <div class="mt-6 pt-4 border-t border-gray-100 flex justify-end gap-2">
              <a href="/admin/estofador/<%= estofador.codUsuario %>/trabalhos"
                  class="inline-flex items-center gap-1 text-xs font-semibold text-zinc-600 hover:text-green-700 transition-colors bg-zinc-50 hover:bg-green-50 px-2.5 py-1.5 rounded-lg border border-zinc-200 hover:border-green-200">
                  <i class="bi bi-journal-check"></i> Ver Trabalhos
                </a>
              <button
                onclick="abrirModalEditar('<%= estofador.codUsuario %>', '<%= estofador.nome %>', '<%= estofador.email %>')"
                class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors text-sm"
                title="Editar Perfil">
                <i class="bi bi-pencil-square"></i>
              </button>
                <form action="/admin/estofador/<%= estofador.codUsuario %>/excluir" method="POST"
                onsubmit="return confirm('Tem certeza que deseja remover o acesso deste estofador?')">
                <button type="submit"
                  class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors text-sm"
                  title="Remover Acesso">
                  <i class="bi bi-trash3"></i>
                </button>
              </form>
            </div>
          </div>
          <% }); %>
            <% } else { %>
              <div class="col-span-full bg-white border border-gray-200 rounded-xl p-12 text-center text-gray-400">
                <i class="bi bi-people text-4xl block mb-2 text-gray-300"></i>
                Nenhum estofador encontrado no banco de dados.
              </div>
              <% } %>
    </div>
  </main>

  <div id="modalNovo"
    class="hidden fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50 animate-fade-in">
    <div class="bg-white rounded-xl shadow-xl border border-gray-200 w-full max-w-md overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
        <h3 class="font-bold text-gray-800 flex items-center gap-2"><i class="bi bi-person-plus text-green-900"></i>
          Cadastrar Estofador</h3>
        <button onclick="fecharModalNovo()" class="text-gray-400 hover:text-gray-600 text-xl"><i
            class="bi bi-x-lg"></i></button>
      </div>
      <form action="/admin/estofador/novo" method="POST" class="p-6 space-y-4">
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Nome Completo</label>
          <input type="text" name="nome" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-green-900">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">E-mail institucional</label>
          <input type="email" name="email" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-green-900">
        </div>
        <p class="text-xs text-amber-600 bg-amber-50 p-2.5 rounded-lg border border-amber-100"><i
            class="bi bi-info-circle"></i> A senha padrão de acesso para novos usuários criados será
          <strong>123456</strong>.</p>
        <div class="pt-2 flex justify-end gap-2">
          <button type="button" onclick="fecharModalNovo()"
            class="px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-200">Cancelar</button>
          <button type="submit"
            class="px-4 py-2 bg-green-950 text-white font-medium rounded-lg text-sm hover:bg-green-900">Salvar
            Profissional</button>
        </div>
      </form>
    </div>
  </div>

  <div id="modalEditar" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-xl shadow-xl border border-gray-200 w-full max-w-md overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
        <h3 class="font-bold text-gray-800 flex items-center gap-2"><i class="bi bi-pencil-square text-blue-600"></i>
          Editar Informações</h3>
        <button onclick="fecharModalEditar()" class="text-gray-400 hover:text-gray-600 text-xl"><i
            class="bi bi-x-lg"></i></button>
      </div>
      <form id="formEditar" method="POST" class="p-6 space-y-4">
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Nome Completo</label>
          <input type="text" id="editarNome" name="nome" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-blue-600">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">E-mail</label>
          <input type="email" id="editarEmail" name="email" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-blue-600">
        </div>
        <div class="pt-2 flex justify-end gap-2">
          <button type="button" onclick="fecharModalEditar()"
            class="px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-200">Cancelar</button>
          <button type="submit"
            class="px-4 py-2 bg-blue-600 text-white font-medium rounded-lg text-sm hover:bg-blue-700">Atualizar
            Dados</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function abrirModalNovo() {
      document.getElementById('modalNovo').classList.remove('hidden');
    }
    function fecharModalNovo() {
      document.getElementById('modalNovo').classList.add('hidden');
    }

    function abrirModalEditar(id, nome, email) {
      // Altera o destino do formulário colocando o ID correto na URL
      document.getElementById('formEditar').action = '/admin/estofador/' + id + '/editar';
      // Preenche os campos do formulário com os dados atuais do banco
      document.getElementById('editarNome').value = nome;
      document.getElementById('editarEmail').value = email;
      // Mostra o modal na tela
      document.getElementById('modalEditar').classList.remove('hidden');
    }
    function fecharModalEditar() {
      document.getElementById('modalEditar').classList.add('hidden');
    }
  </script>
</body>

</html>