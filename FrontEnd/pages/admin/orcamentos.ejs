<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Novos Orçamentos - Estoffe Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-gray-50 min-h-screen">

  <nav class="bg-green-950 text-white px-6 py-4 flex justify-between items-center shadow-md">
    <div class="flex items-center gap-3">
      <span class="text-xl font-bold tracking-wider">ESTOFFE ADMIN</span>
      <span class="bg-red-500 text-xs px-2.5 py-0.5 rounded-full font-semibold uppercase tracking-wide">Gerente</span>
    </div>
    <a href="/admin-dashboard"
      class="text-gray-300 hover:text-white transition-colors flex items-center gap-1.5 text-sm font-medium">
      <i class="bi bi-speedometer2"></i> Voltar ao Painel
    </a>
  </nav>

  <main class="p-6 md:p-12 max-w-7xl mx-auto">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-800">Novos Orçamentos</h1>
      <p class="text-gray-600 mt-1">Lista de pedidos recebidos com o status "Aberto" aguardando análise ou aprovação.
      </p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="p-6 overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="text-xs font-semibold text-gray-500 uppercase border-b border-gray-200">
              <th class="pb-3">Nº Pedido</th>
              <th class="pb-3">Cliente</th>
              <th class="pb-3">Data de Entrada</th>
              <th class="pb-3 text-right">Ações</th>
            </tr>
          </thead>
          <tbody class="text-sm divide-y divide-gray-100 text-gray-600">
            <% if (orcamentos && orcamentos.length> 0) { %>
              <% orcamentos.forEach(function(item) { %>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="py-4 font-bold text-green-900">#<%= item.codPedido %>
                  </td>

                  <td class="py-4 font-medium text-gray-800">
                    <%= item.nomeCliente %>
                  </td>

                  <td class="py-4">
                    <%= item.dataPedido ? new Date(item.dataPedido).toLocaleDateString('pt-BR') : '---' %>
                  </td>

                  <td class="py-4 text-right">
                    <a href="/admin/pedido/<%= item.codPedido %>/analisar"
                      class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 hover:bg-blue-100 text-blue-700 rounded-lg text-xs font-semibold transition-colors shadow-sm border border-blue-100">
                      <i class="bi bi-search text-xs"></i> Analisar
                    </a>
                  </td>
                </tr>
                <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="4" class="py-8 text-center text-gray-400">Nenhum novo orçamento em aberto encontrado.
                      </td>
                    </tr>
                    <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</body>

</html>