<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Meu Perfil - Estoffe</title>
    <link
      rel="icon"
      type="image/png"
      href="../../image/Icons/favicon-96x96.png"
      sizes="96x96"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="stylesheet" href="/../css/style.css">
  </head>

  <body class="bg-gray-100 pt-24">
    <header
      id="main-header"
      class="flex items-center justify-between p-4 bg-green-950 shadow-md fixed top-0 left-0 w-full z-50"
    >
      <a id="header-logo" href="/client-dashboard" class="flex items-center">
        <img
          id="logo-img"
          src="../../image/LogoNavBar.png"
          alt="Logo Estoffe"
          class="h-16 w-auto"
        />
      </a>

      
        <nav id="menu"
            class="fixed left-0 -top-full w-full h-screen bg-green-900/90 flex flex-col items-center justify-center transition-all duration-300 md:static md:h-auto md:w-auto md:flex-row md:bg-transparent">
            <ul
                class="flex flex-col items-center gap-8 text-sm font-medium uppercase tracking-widest md:flex-row md:space-x-8 md:gap-0">
                <li>
                    <a href="/" class="nav-link-item text-white font-bold transition-colors duration-300"
                        data-active="true">
                        <i class="bi bi-house-door mr-1"></i>Início
                    </a>
                </li>
                <li>
                    <a href="/produtos"
                        class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                        <i class="bi bi-bag mr-1"></i>Produtos
                    </a>
                </li>
                <li>
                    <a href="/sobre"
                        class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                        <i class="bi bi-info-circle mr-1"></i>Sobre
                    </a>
                </li>
                <li>
                    <a href="/contato"
                        class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                        <i class="bi bi-envelope mr-1"></i>Contato
                    </a>
                </li>

                <% if (typeof usuario !=='undefined' && usuario) { %>
                    <li>
                        <a href="<%= usuario.tipo === 'client' ? '/client-dashboard' : '/perfil' %>"
                            class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                            <i class="bi bi-person-circle mr-1"></i>Meu Perfil
                        </a>
                    </li>
                    <li>
                        <a href="/logout"
                            class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                            <i class="bi bi-box-arrow-right mr-1"></i>Sair
                        </a>
                    </li>
                    <% } else { %>
                        <li>
                            <a href="/login"
                                class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                                <i class="bi bi-person mr-1"></i>Login
                            </a>
                        </li>
                        <% } %>
            </ul>
        </nav>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8 space-y-8">
      <div class="bg-white rounded-lg shadow-xl overflow-hidden">
        <button
          type="button"
          onclick="toggleGaveta('conteudo-perfil', 'seta-perfil')"
          class="w-full bg-green-900 p-6 text-white flex items-center justify-between hover:bg-green-950 transition-colors focus:outline-none"
        >
          <div class="flex items-center space-x-4 text-left">
            <div
              class="bg-green-800 p-4 rounded-full border-2 border-white text-3xl"
            >
              <i class="bi bi-person"></i>
            </div>
            <div>
              <h2 class="text-2xl font-bold uppercase tracking-wide">
                Minha Conta
              </h2>
              <p class="text-green-200 text-sm">
                Clique para ocultar/exibir suas informações pessoais e de
                entrega
              </p>
            </div>
          </div>

          <div class="text-2xl pr-2">
            <i
              id="seta-perfil"
              class="bi bi-chevron-down inline-block transition-transform duration-300 rotate-180"
            ></i>
          </div>
        </button>

        <div
          id="conteudo-perfil"
          class="overflow-hidden transition-all duration-500 ease-in-out bg-white"
          style="max-height: 2000px"
        >
          <form
            action="/cliente/atualizar-perfil"
            method="POST"
            class="p-6 space-y-6"
          >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2"
                  >Nome Completo</label
                >
                <input
                  type="text"
                  name="nome"
                  value="<%= typeof usuario !== 'undefined' ? usuario.nome : 'Nome do Cliente' %>"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-900 focus:outline-none transition-all"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2"
                  >E-mail</label
                >
                <input
                  type="email"
                  name="email"
                  value="<%= typeof usuario !== 'undefined' ? usuario.email : 'cliente@email.com' %>"
                  disabled
                  class="w-full px-4 py-2 border border-gray-200 bg-gray-100 text-gray-500 rounded-lg cursor-not-allowed"
                />
                <p class="text-xs text-gray-400 mt-1">
                  O e-mail não pode ser alterado por motivos de segurança.
                </p>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2"
                  >Telefone / WhatsApp</label
                >
                <input
                  type="text"
                  name="telefone"
                  value="<%= typeof usuario !== 'undefined' && usuario.telefone ? usuario.telefone : '' %>"
                  placeholder="(11) 99999-9999"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-900 focus:outline-none transition-all"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2"
                  >CPF</label
                >
                <input
                  type="text"
                  name="cpf"
                  value="<%= typeof usuario !== 'undefined' && usuario.cpf ? usuario.cpf : '' %>"
                  placeholder="000.000.000-00"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-900 focus:outline-none transition-all"
                />
              </div>

              <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-gray-700 mb-2"
                  >Endereço Completo de Entrega</label
                >
                <input
                  type="text"
                  name="endereco"
                  value="<%= typeof usuario !== 'undefined' && usuario.endereco ? usuario.endereco : '' %>"
                  placeholder="Rua, Número, Bairro, Cidade - Estado"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-900 focus:outline-none transition-all"
                />
              </div>
            </div>

            <hr class="border-gray-200 my-6" />

            <div>
              <h3 class="text-lg font-bold text-gray-800 mb-2">
                <i class="bi bi-lock mr-2"></i>Alterar Senha
              </h3>
              <p class="text-xs text-gray-500 mb-4">
                A senha deve conter no mínimo 8 caracteres para garantir a
                segurança da criptografia.
              </p>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-2"
                    >Nova Senha</label
                  >
                  <input
                    type="password"
                    name="novaSenha"
                    minlength="8"
                    placeholder="No mínimo 8 caracteres"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-900 focus:outline-none transition-all"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-2"
                    >Confirmar Nova Senha</label
                  >
                  <input
                    type="password"
                    name="confirmarSenha"
                    minlength="8"
                    placeholder="Confirme a nova senha"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-900 focus:outline-none transition-all"
                  />
                </div>
              </div>
            </div>

            <div class="flex justify-end pt-4">
              <button
                type="submit"
                class="bg-green-900 hover:bg-green-950 text-white font-bold px-6 py-2.5 rounded-lg shadow-md transition-colors duration-300 flex items-center"
              >
                <i class="bi bi-check-circle mr-2"></i>Salvar Alterações
              </button>
            </div>
          </form>
        </div>
      </div>
      <div class="bg-white rounded-lg shadow-xl overflow-hidden">

            <button type="button" onclick="Gaveta()"
                class="w-full bg-gray-800 p-6 text-white flex items-center justify-between hover:bg-gray-700 transition-colors focus:outline-none">

                <div class="flex items-center space-x-4 text-left">
                    <div class="bg-gray-700 p-3 rounded-full text-2xl">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold uppercase tracking-wide">Meus Pedidos e Orçamentos</h2>
                        <p class="text-gray-400 text-sm">Clique para expandir e acompanhar seus serviços.</p>
                    </div>
                </div>

                <div class="text-2xl pr-2">
                    <i id="seta-gaveta" class="bi bi-chevron-down inline-block transition-transform duration-300"></i>
                </div>
            </button>

            <div id="conteudo-gaveta" class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out bg-white">
                <div class="p-6 overflow-x-auto border-t border-gray-100">
                    <% if (typeof pedidos !=='undefined' && pedidos && pedidos.length> 0) { %>
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b-2 border-gray-200 text-gray-600 text-sm font-bold bg-gray-50">
                                    <th class="p-3">Nº Pedido</th>
                                    <th class="p-3">Data</th>
                                    <th class="p-3">Status</th>
                                    <th class="p-3 text-right">Valor Final</th>
                                </tr>
                            </thead>
                            <tbody class="text-gray-700 text-sm divide-y divide-gray-100">
                                <% pedidos.forEach(function(pedido) { %>
                                    <tr class="hover:bg-gray-50 transition-colors">
                                        <td class="p-3 font-semibold text-green-900">#<%= pedido.codPedido %>
                                        </td>

                                        <td class="p-3">
                                            <%= pedido.dataPedido ? new
                                                Date(pedido.dataPedido).toLocaleDateString('pt-BR') : '---' %>
                                        </td>

                                        <td class="p-3">
                                            <% if (pedido.status==='Aberto' || pedido.status==='Orçamento' ) { %>
                                                <span
                                                    class="px-2.5 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">Orçamento</span>
                                                <% } else if (pedido.status==='Em Produção' ||
                                                    pedido.status==='Em produção' ) { %>
                                                    <span
                                                        class="px-2.5 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800">Em
                                                        Produção</span>
                                                    <% } else if (pedido.status==='Concluído' ||
                                                        pedido.status==='Entregue' || pedido.status==='Pronto' ) { %>
                                                        <span
                                                            class="px-2.5 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                                                            <%= pedido.status %>
                                                        </span>
                                                        <% } else { %>
                                                            <span
                                                                class="px-2.5 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">
                                                                <%= pedido.status %>
                                                            </span>
                                                            <% } %>
                                        </td>

                                        <td class="p-3 text-right font-bold text-gray-900">
                                            R$ <%= (pedido && pedido.valor_final) ?
                                                Number(pedido.valor_final).toFixed(2) : '0.00' %>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                        <% } else { %>
                            <div class="text-center py-8 text-gray-500">
                                <i class="bi bi-folder-x text-4xl block mb-2 text-gray-300"></i>
                                <p>Você ainda não possui nenhum orçamento ou pedido registrado.</p>
                            </div>
                            <% } %>
                </div>
            </div>

            <script>
                function Gaveta() {
                    const conteudo = document.getElementById('conteudo-gaveta');
                    const seta = document.getElementById('seta-gaveta');

                    // Se a gaveta estiver fechada (altura zero), abrimos calculando o tamanho real dela
                    if (conteudo.style.maxHeight === '0px' || !conteudo.style.maxHeight) {
                        conteudo.style.maxHeight = conteudo.scrollHeight + 'px';
                        seta.style.transform = 'rotate(180deg)'; // Gira a seta para cima
                    } else {
                        // Se já estiver aberta, fechamos voltando a altura para zero
                        conteudo.style.maxHeight = '0px';
                        seta.style.transform = 'rotate(0deg)'; // Volta a seta para baixo
                    }
                }
            </script>
    </main>

    <!-- Scripts-->
    <script>
      function toggleGaveta(idConteudo, idSeta) {
        const conteudo = document.getElementById(idConteudo);
        const seta = document.getElementById(idSeta);

        // Ajuste necessário para sincronizar o estado inicial da gaveta aberta
        if (conteudo.style.maxHeight === "2000px") {
          conteudo.style.maxHeight = conteudo.scrollHeight + "px";
        }

        // Se estiver fechada ou sem definição de altura, abre
        if (conteudo.style.maxHeight === "0px" || !conteudo.style.maxHeight) {
          conteudo.style.maxHeight = conteudo.scrollHeight + "px";
          seta.style.transform = "rotate(180deg)";
        } else {
          // Se estiver aberta, fecha
          conteudo.style.maxHeight = "0px";
          seta.style.transform = "rotate(0deg)";
        }
      }

      // Pequeno ajuste para garantir o funcionamento correto do scrollHeight ao carregar a página
      window.addEventListener("DOMContentLoaded", () => {
        const perf = document.getElementById("conteudo-perfil");
        perf.style.maxHeight = perf.scrollHeight + "px";
      });
    </script>
    <script src="../../pages/animacoes/anima.js"></script>
  </body>
</html>
