<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/../image/Icons/favicon-96x96(1).png" sizes="96x96" />
    <title>Produtos - Estoffe</title>
    <script src="mudaNav.js"></script>
    <link rel="icon" type="image/png" href="/../image/Icons/favicon-96x96.png" sizes="96x96" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/../css/style.css">
</head>


<body>
    <header id="main-header"
        class="flex items-center justify-between p-4 bg-green-950 shadow-md fixed top-0 left-0 w-full z-50 transition-all duration-500">

        <a id="header-logo" href="/" class="flex items-center">
            <img id="logo-img" src="../image/LogoNavBar.png" alt="Logo Estoffe"
                class="h-16 md:h-19 w-auto transition-all duration-500">
        </a>

        <button id="menu-btn" class="block md:hidden text-white focus:outline-none z-50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16">
                </path>
            </svg>
        </button>

        <nav id="menu" class="fixed left-0 -top-full w-full h-screen bg-green-900/90 **shadow-lg shadow-green-950/50** flex flex-col items-center justify-center transition-all duration-300 md:static md:h-auto md:w-auto md:flex-row md:bg-transparent filter backdrop-blur-md md:backdrop-blur-5 **md:shadow-none**">
            <ul
                class="flex flex-col items-center gap-8 text-sm font-medium uppercase tracking-widest md:flex-row md:space-x-8 md:gap-0">

                <li>
                    <% if (typeof usuario !=='undefined' && usuario) { %>
                        <a href="/" class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                            <i class="bi bi-house-door mr-1"></i>Início
                        </a>
                        <% } else { %>
                            <a href="/"
                                class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                                <i class="bi bi-house-door mr-1"></i>Início
                            </a>
                            <% } %>
                </li>

                <li>
                    <a href="/produtos" class="nav-link-item text-white font-bold transition-colors duration-300"
                        data-active="true">
                        <i class="bi bi-bag mr-1"></i>Produtos
                    </a>
                </li>
                <li>
                    <a href="/sobre"
                        class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                        <i class="bi bi-info-circle mr-1"></i>Sobre
                    </a>
                </li>
                <li>
                    <a href="/contato"
                        class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                        <i class="bi bi-envelope mr-1"></i>Contato
                    </a>
                </li>

                <% if (typeof usuario !=='undefined' && usuario) { %>
                    <% if (usuario.tipo==='admin' ) { %>
                        <li>
                            <a href="/admin-dashboard"
                                class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                                <i class="bi bi-shield-lock mr-1"></i> Painel Administrativo
                            </a>
                        </li>

                        <% } else if (usuario.tipo==='estofador' ) { %>
                            <li>
                                <a href="/estofador-dashboard"
                                    class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                                    <i class="bi bi-tools mr-1"></i> Painel do Estofador
                                </a>
                            </li>

                            <% } else { %>
                                <li>
                                    <a href="<%= usuario.tipo === 'client' ? '/client-dashboard' : '/perfil' %>"
                                        class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                                        <i class="bi bi-person-circle mr-1"></i> Meu Perfil
                                    </a>
                                </li>
                                <% } %>

                                    <li>
                                        <a href="/logout"
                                            class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                                            <i class="bi bi-box-arrow-right mr-1"></i> Sair
                                        </a>
                                    </li>

                                    <% } else { %>
                                        <li>
                                            <a href="/login"
                                                class="nav-link-item text-gray-300 hover:text-white transition-colors duration-300">
                                                <i class="bi bi-person mr-1"></i> Login
                                            </a>
                                        </li>
                                        <% } %>
            </ul>
        </nav>
    </header>

    <section class="relative bg-green-950 text-white pt-80 pb-50 px-6 md:px-25 lg:px-33 overflow-hidden">
        <div class="absolute inset-0 opacity-5 pointer-events-none flex items-center justify-center">
            <span class="text-[26vw] text-white font-serif font-bold italic select-none">Estoffe</span>
        </div>

        <div
            class="max-w-7xl mx-auto relative z-10 text-center md:text-left flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <div>
                <span class="text-xs font-bold uppercase tracking-[0.6em] text-green-400 mb-3 block">Catálogo
                    Exclusivo</span>
                <h1 class="text-5xl md:text-7xl font-light tracking-tight">Nossa <span
                        class="font-extrabold text-white">Coleção</span></h1>
                <div class="w-16 h-[2px] bg-green-400 mt-4 mx-auto md:mx-0"></div>
            </div>
            <p class="text-gray-300 font-light max-w-md text-sm md:text-base leading-relaxed">
                Móveis de alta costura com acabamento artesanal, ergonomia premium e tecidos nobres selecionados para o
                seu projeto.
            </p>
        </div>
    </section>

    <div class="max-w-7xl mx-auto px-6 md:px-16 lg:px-24 pt-10">
        <div class="flex flex-wrap justify-center gap-4 border-b border-gray-100 pb-6">
            <a href="/produtos"
                class="px-4 py-2 text-xs uppercase tracking-wider rounded-sm transition-all duration-300 <%= !categoriaAtiva ? 'bg-green-950 text-white font-bold' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
                Todos
            </a>

            <% categorias.forEach(categoria=> { %>
                <a href="/produtos?categoria=<%= categoria.codCategoria %>"
                    class="px-4 py-2 text-xs uppercase tracking-wider rounded-sm transition-all duration-300 <%= categoriaAtiva == categoria.codCategoria ? 'bg-green-950 text-white font-bold' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
                    <%= categoria.nome %>
                </a>
                <% }) %>
        </div>
    </div>

    <main class="py-12 px-6 md:px-16 lg:px-24 flex-grow">
        <div class="max-w-7xl mx-auto">

            <% if (produtos.length===0) { %>
                <div class="text-center py-12 text-gray-500">
                    <i class="bi bi-exclamation-circle text-3xl block mb-2"></i>
                    Nenhum produto encontrado nesta categoria.
                </div>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">

                        <% produtos.forEach(produto=> { %>
                            <div
                                class="group bg-white rounded-sm overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
                                <div>
                                    <div class="aspect-square w-full overflow-hidden bg-gray-100 relative">
                                        <% if (produto.preco> 1500) { %>
                                            <span
                                                class="absolute top-4 left-4 z-10 bg-green-950 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-sm">Alta
                                                Costura</span>
                                            <% } %>

                                                <img src="<%= produto.imagem %>" alt="<%= produto.nome %>"
                                                    class="w-full h-full object-cover object-center group-hover:scale-103 transition-transform duration-500">
                                    </div>

                                    <div class="p-6">
                                        <div class="flex items-center justify-between mb-2">
                                            <h3 class="text-xl font-bold text-gray-900">
                                                <%= produto.nome %>
                                            </h3>
                                            <span
                                                class="text-xs font-semibold text-green-700 bg-green-50 px-2 py-0.5 rounded-sm">R$
                                                <%= parseFloat(produto.preco).toFixed(2).replace('.', ',' ) %>
                                            </span>
                                        </div>
                                        <p class="text-sm text-gray-600 font-light leading-relaxed mb-4">
                                            Mobiliário de alto padrão fabricado com exclusividade pelo Atelier Estoffe,
                                            utilizando materiais nobres selecionados sob rigorosos critérios de
                                            qualidade.
                                        </p>
                                        <div
                                            class="border-t border-gray-100 pt-4 flex flex-wrap gap-2 text-[11px] text-gray-400 uppercase font-medium tracking-wider">
                                            <span><i class="bi bi-sliders mr-1"></i> Alto Padrão</span>
                                            <span>•</span>
                                            <span><i class="bi bi-shield-check mr-1"></i> Garantia Estoffe</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="p-6 pt-0">
                                    <form action="/carrinho/add/<%= produto.codProduto %>" method="POST">
                                        <button type="submit"
                                            class="w-full text-center flex items-center justify-center gap-2 bg-green-950 hover:bg-green-800 text-white font-semibold px-4 py-3 rounded-sm transition-colors duration-300 uppercase tracking-wider text-xs cursor-pointer">
                                            <i class="bi bi-bag-plus"></i> Colocar no Carrinho
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <% }) %>

                    </div>
                    <% } %>
        </div>
        <div class="mt-16 bg-green-900/5 border border-green-900/10 rounded-sm p-8 text-center max-w-3xl mx-auto">
            <i class="bi bi-pencil-square text-2xl text-green-950 block mb-3"></i>
            <h4 class="text-lg font-bold text-gray-900 mb-2">Possui um projeto arquitetônico específico?</h4>
            <p class="text-sm text-gray-600 font-light leading-relaxed max-w-xl mx-auto mb-4">
                Nossa equipe é especializada em executar projetos sob medida em parceria com arquitetos e designers
                de interiores. Adaptamos tamanhos, espumas e costuras.
            </p>
            <a href="contato.html"
                class="text-xs font-bold text-green-950 uppercase tracking-widest hover:text-green-800 transition-colors duration-300">
                Traga seu projeto <i class="bi bi-arrow-right ml-1"></i>
            </a>
        </div>

        </div>
    </main>

    <footer class="bg-green-950 text-gray-400 text-sm py-12 px-6 md:px-16 lg:px-24 border-t border-green-900">
        <div
            class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
            <div>
                <p class="text-white font-bold text-lg tracking-wider uppercase">Estoffe</p>
                <p class="text-xs text-gray-400 mt-1">&copy; 2026 Estoffe Estofaria Premium. Todos os direitos
                    reservados.</p>
            </div>

            <div class="flex space-x-6 text-xl">
                <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-instagram"></i></a>
                <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-facebook"></i></a>
                <a href="#" class="hover:text-white transition-colors duration-300"><i class="bi bi-whatsapp"></i></a>
            </div>
        </div>
    </footer>

    <script src="/../pages/animacoes/anima.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"
        integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y"
        crossorigin="anonymous"></script>

    <script>
        // Pergunta para o servidor se o usuário está logado
        fetch('/api/auth-status')
            .then(response => response.json())
            .then(data => {
                const loginBtn = document.getElementById('menu-login');
                const perfilBtn = document.getElementById('menu-perfil');
                const sairBtn = document.getElementById('menu-sair');

                if (data.logado) {
                    // Se estiver logado: esconde o login e mostra perfil/sair
                    loginBtn.classList.add('hidden');
                    perfilBtn.classList.remove('hidden');
                    sairBtn.classList.remove('hidden');
                }
            })
            .catch(err => console.error("Erro ao verificar autenticação:", err));
    </script>
</body>

</html>